# ─────────────────────────────────────────────────────────────
# NutriBite — Environment Variables Template
# Copy this file to .env and fill in your own values.
# NEVER commit the .env file to git.
# ─────────────────────────────────────────────────────────────

# ── Server ───────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# ── MongoDB ───────────────────────────────────────────────────
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>
MONGO_URI=mongodb+srv://YOUR_DB_USER:YOUR_DB_PASSWORD@your-cluster.mongodb.net/nutrikid?appName=Cluster0

# ── Auth ─────────────────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_string_min_64_chars
JWT_EXPIRE=30d

# ── Email / OTP ───────────────────────────────────────────────
OTP_MODE=email
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password
SMTP_FROM=NutriBite<your_email@gmail.com>

# ── OTP Hardening ─────────────────────────────────────────────
OTP_EXPIRES_SECONDS=120
OTP_MAX_ATTEMPTS=3
OTP_RESEND_COOLDOWN_SECONDS=30

# ── Login Lockout ─────────────────────────────────────────────
LOGIN_MAX_FAILS=5
LOGIN_LOCK_MINUTES=15

# ── AI Service ────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
AI_SERVICE_URL=http://localhost:8000
